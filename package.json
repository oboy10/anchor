{
  "name": "milpitas-hacks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:anchor": "npm run test:anchor:protocol && npm run test:anchor:workflow",
    "test:anchor:protocol": "node --import tsx --test tests/anchor-protocol.test.ts",
    "test:anchor:workflow": "node --conditions react-server --import tsx tests/anchor-workflow.test.ts",
    "test:sms": "node --conditions react-server --import tsx --test tests/sms.test.ts",
    "firebase:deploy-rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:cleanup": "node scripts/cleanup-firebase.mjs",
    "vercel:env": "node scripts/sync-vercel-env.mjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "clsx": "^2.1.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.4.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
