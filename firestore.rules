rules_version = '2';

/**
 * Anchor Firestore rules — local-first build.
 *
 * Application data is NOT stored in Firestore; it lives in each user's browser
 * (see lib/local/db) and travels inside self-contained share links. The only
 * server-side collections (all Admin SDK only, no client access):
 *   - registeredEmails — SHA-256 email hashes
 *   - pendingVerifications — short-lived verification codes (hashed)
 *   - registeredIdentities — SHA-256 email/phone hashes (legacy; unused)
 *
 * Writes to that collection go through the Admin SDK (server-side), which
 * bypasses these rules; clients are denied all direct access.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    // Email hash registry — server-only (Admin SDK). No client access.
    match /registeredEmails/{hash} {
      allow read, write: if false;
    }

    match /pendingVerifications/{hash} {
      allow read, write: if false;
    }

    match /registeredIdentities/{hash} {
      allow read, write: if false;
    }

    match /contactDirectory/{hash} {
      allow read, write: if false;
    }

    match /credentialDeliveries/{token} {
      allow read, write: if false;
    }

    match /credentialRequests/{token} {
      allow read, write: if false;
    }

    // Everything else is denied: no other data is stored here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
