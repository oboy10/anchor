rules_version = '2';

/**
 * Anchor Firestore rules — local-first build.
 *
 * Application data is NOT stored in Firestore; it lives in each user's browser
 * (see lib/local/db) and travels inside self-contained share links. The only
 * server-side collection is `registeredEmails`, which holds SHA-256 hashes of
 * registered emails (no plaintext, no recoverable personal data).
 *
 * Writes to that collection go through the Admin SDK (server-side), which
 * bypasses these rules; clients are denied all direct access.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    // Email hash registry — server-only (Admin SDK). No client access.
    match /registeredEmails/{hash} {
      allow read, write: if false;
    }

    // Everything else is denied: no other data is stored here.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
